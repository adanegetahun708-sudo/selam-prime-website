# ==========================================
# FRONTEND CONFIGURATION
# ==========================================
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_APP_NAME=Selam Prime Valuation
REACT_APP_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
REACT_APP_ENVIRONMENT=development

# ==========================================
# BACKEND CONFIGURATION
# ==========================================
NODE_ENV=development
PORT=5000
APP_NAME=Selam Prime Valuation API
APP_URL=http://localhost:3000

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=selam_user
DB_PASSWORD=selam_password
DB_NAME=selam_prime
DATABASE_URL=postgresql://selam_user:selam_password@localhost:5432/selam_prime

# ==========================================
# AUTHENTICATION
# ==========================================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_at_least_32_chars
JWT_EXPIRE=7d
BCRYPT_ROUNDS=10

# ==========================================
# EMAIL CONFIGURATION (SMTP)
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM_NAME=Selam Prime Valuation
SMTP_FROM_EMAIL=noreply@selamprime.com

# ==========================================
# ADMIN PANEL INITIAL SETUP
# ==========================================
ADMIN_EMAIL=admin@selamprime.com
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User
ADMIN_PASSWORD=Admin@123456

# ==========================================
# AWS S3 FILE UPLOADS
# ==========================================
USE_AWS_S3=false
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_S3_BUCKET=selam-prime-uploads
AWS_REGION=us-east-1

# ==========================================
# GOOGLE MAPS & SERVICES
# ==========================================
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ==========================================
# WHATSAPP INTEGRATION
# ==========================================
WHATSAPP_ENABLED=true
WHATSAPP_PHONE_NUMBER=+251911223344
WHATSAPP_BUSINESS_API_TOKEN=your_whatsapp_token

# ==========================================
# BACKUP CONFIGURATION
# ==========================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=./backups

# ==========================================
# SECURITY
# ==========================================
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
MAX_FILE_SIZE=5242880

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=debug
LOG_FILE_PATH=./logs/app.log

# ==========================================
# PAGINATION
# ==========================================
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100
